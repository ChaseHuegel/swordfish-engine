#version 1.0;
#namespace WaywardBeyond.Client.Core.Characters;

enum GameMode
{
    Adventure;
    Creative;
}

message CharacterEntityData
{
    string Guid = 0;
    
    double X = 1;
    double Y = 2;
    double Z = 3;
    
    float OrientationX = 4;
    float OrientationY = 5;
    float OrientationZ = 6;
    float OrientationW = 7;
    
    float ScaleX = 8;
    float ScaleY = 9;
    float ScaleZ = 10;
    
    GameMode GameMode = 11;
}